<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Kreta.MainWindow"
        Title="EvolKréta - Önfejlesztő Iskolai Rendszer"
        Width="900" Height="600"
        WindowStartupLocation="CenterScreen">

    <!-- Fő rács: Bal oldali menü (220px) és Jobb oldali tartalom (*) -->
    <Grid ColumnDefinitions="220, *">

        <!-- 1. ZÓNA: BAL OLDALSÁV (Sidebar) -->
        <Border Grid.Column="0" Background="#2C3E50" BorderBrush="#1A252F" BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto, Auto, *, Auto">
                
                <!-- Alkalmazás címe -->
                <StackPanel Grid.Row="0" Margin="15">
                    <TextBlock Text="🏫 EvolKréta" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="Önfejlesztő verzió" FontSize="10" Foreground="#BDC3C7" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Szerepkör választó a menüben -->
                <StackPanel Grid.Row="1" Margin="15,0,15,10">
                    <TextBlock Text="🔑 Szerepkör szimuláció:" FontSize="11" Foreground="#BDC3C7" Margin="0,0,0,5"/>
                    <ComboBox x:Name="RoleSelector" HorizontalAlignment="Stretch" SelectedIndex="0">
                        <ComboBoxItem Content="👨‍🎓 Diák (Kovács János)" Tag="Student"/>
                        <ComboBoxItem Content="👩‍🏫 Tanár (Szabó Mária)" Tag="Teacher"/>
                        <ComboBoxItem Content="👑 Igazgató (Nagy Péter)" Tag="Director"/>
                    </ComboBox>
                </StackPanel>
                
                <!-- Dinamikus Menügombok Panelje (Ide kerülnek az AI által generált gombok) -->
                <ScrollViewer Grid.Row="2" Margin="10">
                    <StackPanel x:Name="SidebarMenuPanel" Spacing="5">
        
                        <!-- [INJECT BUTTON] -->
                    </StackPanel>
                </ScrollViewer>

                <!-- Rendszerállapot kijelző alul -->
                <StackPanel Grid.Row="3" Margin="10" Spacing="2">
                    <TextBlock x:Name="EvolverStatusText" FontSize="10" Foreground="#2ECC71" Text="🟢 Evolúció: Aktív" TextWrapping="Wrap"/>
                    <TextBlock x:Name="StatusText" FontSize="9" Foreground="#95A5A6" Text="Készen áll a fejlesztésre." TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- JOBB OLDALI TARTALOM (Központi kijelző és az AI vezérlő) -->
        <Grid Grid.Column="1" RowDefinitions="*, Auto">

            <!-- 2. ZÓNA: KÖZPONTI KIJELZŐ (Ide töltődnek be az ablakok) -->
            <Border Grid.Row="0" Background="#F8F9F9" Padding="20">
                <ContentControl x:Name="MainContentArea">
                    <TextBlock Text="Üdvözöljük az EvolKrétában! Válasszon funkciót a bal oldalon, vagy kérjen újat alul." 
                               VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#7F8C8D" FontSize="14"/>
                </ContentControl>
            </Border>

            <!-- 3. ZÓNA: ALSÓ AI STÚDIÓ (A fejlesztő pult) -->
            <Border Grid.Row="1" Background="#EAEDED" Padding="15" BorderBrush="#BDC3C7" BorderThickness="0,1,0,0">
                <Grid ColumnDefinitions="*, Auto, Auto, Auto">
                    
                    <!-- Prompt beviteli mező -->
                    <TextBox x:Name="PromptInput" Grid.Column="0" 
                             PlaceholderText="Írja be, milyen új iskolai funkciót vagy ablakot szeretne fejleszteni..." 
                             Margin="5" Height="40" VerticalContentAlignment="Center"/>

                    <!-- 🤖 Fejlesztés indítása gomb -->
                    <Button x:Name="AiButton" Grid.Column="1" Content="🤖 Fejlesztés" 
                            Margin="5" Padding="15,0" Height="40" VerticalContentAlignment="Center" Background="#3498DB" Foreground="White"/>

                    <!-- Jóváhagyás gomb (Alapértelmezetten rejtett) -->
                    <Button x:Name="ApproveButton" Grid.Column="2" Content="✅ Jóváhagyás" 
                            Margin="5" Height="40" VerticalContentAlignment="Center" Background="#2ECC71" Foreground="White" IsVisible="False"/>

                    <!-- Elvetés gomb (Alapértelmezetten rejtett) -->
                    <Button x:Name="DiscardButton" Grid.Column="3" Content="❌ Elvetés" 
                            Margin="5" Height="40" VerticalContentAlignment="Center" Background="#E74C3C" Foreground="White" IsVisible="False"/>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</Window>